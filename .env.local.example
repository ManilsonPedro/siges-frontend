# =============================================================
# AMBIENTE DE DESENVOLVIMENTO — Frontend (Next.js)
# Copie para .env.local. Carregado automaticamente pelo Next.js
# quando corre `npm run dev`.
# =============================================================

# URL do backend local (FastAPI a correr em localhost:8000)
# Nota: NÃO incluir /api/v1 — o cliente HTTP adiciona automaticamente
NEXT_PUBLIC_API_URL=http://localhost:8000

# Modo de desenvolvimento
NEXT_PUBLIC_ENV=development
